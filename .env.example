# Optional. When set, patterns run against Anthropic Claude.
# When unset, every pattern runs with deterministic scripted fake models
# (no network calls) so the library, examples, tests, and playground all
# work without any API key.
ANTHROPIC_API_KEY=

# Optional. Override the Claude model used when ANTHROPIC_API_KEY is set.
# LGP_MODEL=claude-opus-4-8

# Optional. Set to any non-empty value to force fake models even when an
# API key is present (useful for CI and offline demos).
# LGP_FORCE_FAKE=1
